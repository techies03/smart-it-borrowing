# ============================================================
# TrackIT — Environment Variables EXAMPLE
# ============================================================
# Copy this file to .env and fill in your real values.
# Never commit .env to version control!

# ----- Database -----
# Use a standard MySQL JDBC URL. Do not embed credentials in DB_URL.
DB_URL=jdbc:mysql://localhost:3306/trackit?useSSL=false&serverTimezone=Asia/Kuala_Lumpur&allowPublicKeyRetrieval=true
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# ----- App -----
APP_NAME=TrackIT: Smart IT Equipment Inventory System
SESSION_TIMEOUT_MINUTES=30

